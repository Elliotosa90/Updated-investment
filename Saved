<script src="https://js.paystack.co/v1/inline.js"></script>
<script>
// ============================================================
// 🔐 PAYSTACK KEYS — PASTE YOUR KEYS HERE
// ============================================================
// Replace the values below with your actual Paystack keys.
// You can switch between test/live mode in the admin panel.
const PAYSTACK_LIVE_PUBLIC_KEY  = "pk_live_b2e4762baba76699d7217a4009bacb3fbd8b3d31";
const PAYSTACK_LIVE_SECRET_KEY  = "sk_live_c540afd1aa774c364ba11ab2d41cfcbf69b72819";
const PAYSTACK_TEST_PUBLIC_KEY  = "pk_test_7d94595adb7d9380db9ff9d0718c334dc19a4140";
const PAYSTACK_TEST_SECRET_KEY  = "sk_test_df69dcaf5a37852f3f9ae22b2908bcfc0dddc041";
// ============================================================

const JSONBIN_MASTER_KEY = "$2a$10$7LIOruQCVZ2kz.zECoZdOeGnJlwM78ZjJ7K3HxpfglNnITLECcd56";
const JSONBIN_ACCESS_KEY = "";
const JSONBIN_BIN_ID = "6a3193beda38895dfecb685c";

const JSONBIN_URL = `https://api.jsonbin.io/v3/b/${JSONBIN_BIN_ID}`;

function getHeaders() {
    const headers = { 'X-Master-Key': JSONBIN_MASTER_KEY };
    if (JSONBIN_ACCESS_KEY) headers['X-Access-Key'] = JSONBIN_ACCESS_KEY;
    return headers;
}

let appData = null;
let currentUser = null;
let currentUserData = null;
let isAdminLoggedIn = false;
let currentTxTab = 'all';

// Get the active Paystack keys based on the current mode
function getPaystackKeys() {
    const mode = (appData && appData.settings && appData.settings.paystackMode) || 'live';
    if (mode === 'test') {
        return {
            publicKey: (appData && appData.settings && appData.settings.paystackTestPublicKey) || PAYSTACK_TEST_PUBLIC_KEY,
            secretKey: (appData && appData.settings && appData.settings.paystackTestSecretKey) || PAYSTACK_TEST_SECRET_KEY,
            mode: 'test'
        };
    }
    return {
        publicKey: (appData && appData.settings && appData.settings.paystackPublicKey) || PAYSTACK_LIVE_PUBLIC_KEY,
        secretKey: (appData && appData.settings && appData.settings.paystackSecretKey) || PAYSTACK_LIVE_SECRET_KEY,
        mode: 'live'
    };
}

async function loadData() {
    try {
        const res = await fetch(JSONBIN_URL, { headers: getHeaders() });
        if (!res.ok) return null;
        const json = await res.json();
        appData = json.record;
        return appData;
    } catch (e) { return null; }
}

async function saveData() {
    try {
        const res = await fetch(JSONBIN_URL, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', ...getHeaders() },
            body: JSON.stringify(appData)
        });
        return res.ok;
    } catch (e) { return false; }
}

function showAuthTab(tab) {
    document.querySelectorAll('.auth-tabs div').forEach(t => t.classList.remove('active'));
    if (tab === 'login') {
        document.getElementById('loginForm').classList.remove('hidden');
        document.getElementById('registerForm').classList.add('hidden');
        document.querySelector('.auth-tabs div:first-child').classList.add('active');
    } else {
        document.getElementById('loginForm').classList.add('hidden');
        document.getElementById('registerForm').classList.remove('hidden');
        document.querySelector('.auth-tabs div:last-child').classList.add('active');
    }
    ['loginError','registerError','registerSuccess'].forEach(id => document.getElementById(id).textContent = '');
}

function toggleResetPassword() {
    const sec = document.getElementById('resetSection');
    sec.classList.toggle('show');
    document.getElementById('resetUsername').value = '';
    document.getElementById('resetMsg').textContent = '';
}

function resetPasswordRequest() {
    const u = document.getElementById('resetUsername').value.trim();
    const msg = document.getElementById('resetMsg');
    if (!u) { msg.textContent = '❌ Enter your username.'; msg.style.color = '#ef4444'; return; }
    if (!appData || !appData.users[u]) { msg.textContent = '❌ Username not found.'; msg.style.color = '#ef4444'; return; }
    msg.textContent = '⚠️ Password reset is not yet available. Please contact the admin to reset your password.';
    msg.style.color = '#facc15';
}

async function userLogin() {
    const u = document.getElementById('loginUsername').value.trim();
    const p = document.getElementById('loginPassword').value.trim();
    const err = document.getElementById('loginError');
    if (!u || !p) { err.textContent = '❌ Please enter username and password.'; return; }
    await loadData();
    if (!appData) { err.textContent = '❌ Failed to connect.'; return; }
    const user = appData.users[u];
    if (!user || user.password !== p) { err.textContent = '❌ Invalid credentials.'; return; }
    if (user.status === 'closed') { err.textContent = '❌ Account closed.'; return; }
    isAdminLoggedIn = false; currentUser = u; currentUserData = user;
    await applyDailyInterest();
    enterDashboard('user');
}

async function applyDailyInterest() {
    if (!appData || !currentUser || !appData.users[currentUser]) return;
    const user = appData.users[currentUser];
    const rate = (appData.settings && appData.settings.interestRate) || 2;
    const today = new Date().toDateString();
    if (user.lastInterestDate === today) {
        document.getElementById('interestStatus').textContent = '✅ Interest applied today already.';
        return;
    }
    if (user.balance > 0 && user.status === 'active') {
        const interest = user.balance * (rate / 100);
        user.balance += interest;
        user.profit += interest;
        if (!user.transactions) user.transactions = [];
        const now = new Date();
        const ds = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
        user.transactions.push({ date: ds, type: 'profit', amount: interest, description: `Daily interest ${rate}%` });
        user.lastInterestDate = today;
        appData.users[currentUser] = user;
        await saveData();
        document.getElementById('interestStatus').textContent = `✅ ${rate}% daily interest (₦${interest.toFixed(2)}) applied!`;
    } else {
        user.lastInterestDate = today;
        appData.users[currentUser] = user;
        await saveData();
        document.getElementById('interestStatus').textContent = user.status !== 'active' ? '⚠️ Interest only applies to active accounts.' : 'ℹ️ No balance to apply interest on.';
    }
}

function resolveReferralUsername(ref) {
    if (appData.users[ref]) return ref;
    for (const [un, ud] of Object.entries(appData.users)) {
        if (ud.referralCode === ref) return un;
    }
    return null;
}

async function userRegister() {
    const u = document.getElementById('regUsername').value.trim();
    const fn = document.getElementById('regFullname').value.trim();
    const em = document.getElementById('regEmail').value.trim();
    const ph = document.getElementById('regPhone').value.trim();
    const pw = document.getElementById('regPassword').value.trim();
    const ref = document.getElementById('regReferral').value.trim();
    const err = document.getElementById('registerError');
    const suc = document.getElementById('registerSuccess');
    if (!u || !fn || !em || !pw) { err.textContent = '❌ Fill all required fields.'; suc.textContent = ''; return; }
    await loadData();
    if (!appData) { err.textContent = '❌ Failed to connect.'; return; }
    if (appData.users[u]) { err.textContent = '❌ Username taken.'; suc.textContent = ''; return; }

    let referredByUsername = '';
    if (ref) {
        referredByUsername = resolveReferralUsername(ref);
        if (!referredByUsername) {
            err.textContent = '❌ Invalid referral code.'; suc.textContent = ''; return;
        }
    }

    const now = new Date();
    const ds = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
    appData.users[u] = {
        fullName: fn, email: em, phone: ph||'', password: pw, balance: 0, invested: 0,
        profit: 0, referralBonus: 0, referralCode: u, referredBy: referredByUsername,
        plan: 'Basic', status: 'active', createdAt: ds, lastInterestDate: '',
        transactions: [], withdrawals: [], referrals: []
    };
    await saveData();
    err.textContent = ''; suc.textContent = '✅ Account created! Login now.';
    ['regUsername','regFullname','regEmail','regPhone','regPassword','regReferral'].forEach(id => document.getElementById(id).value = '');
}

function userLogout() {
    currentUser = null; currentUserData = null; isAdminLoggedIn = false;
    document.getElementById('authContainer').classList.remove('hidden');
    document.getElementById('userDashboard').classList.remove('active');
    document.getElementById('loginUsername').value = '';
    document.getElementById('loginPassword').value = '';
}

function openAdminLogin() {
    document.getElementById('adminLoginError').textContent = '';
    document.getElementById('adminLoginUser').value = '';
    document.getElementById('adminLoginPass').value = '';
    document.getElementById('adminLoginOverlay').classList.add('active');
}

function closeAdminLogin() { document.getElementById('adminLoginOverlay').classList.remove('active'); }

async function adminLogin() {
    const u = document.getElementById('adminLoginUser').value.trim();
    const p = document.getElementById('adminLoginPass').value.trim();
    const err = document.getElementById('adminLoginError');
    if (!u || !p) { err.textContent = '❌ Enter credentials.'; return; }
    await loadData();
    if (!appData) { err.textContent = '❌ Failed to connect.'; return; }
    if (u === appData.admin.username && p === appData.admin.password) {
        isAdminLoggedIn = true; currentUser = 'admin'; currentUserData = null;
        closeAdminLogin(); enterDashboard('admin');
    } else { err.textContent = '❌ Invalid admin credentials.'; }
}

function enterDashboard(type) {
    document.getElementById('authContainer').classList.add('hidden');
    document.getElementById('userDashboard').classList.add('active');
    if (type === 'admin') {
        document.getElementById('displayUsername').textContent = 'Admin';
        document.getElementById('adminSection').classList.remove('hidden');
        refreshAdminData();
    } else {
        document.getElementById('displayUsername').textContent = currentUserData.fullName || currentUser;
        document.getElementById('adminSection').classList.add('hidden');
        refreshUserData();
    }
}

function showTxTab(tab) {
    currentTxTab = tab;
    document.querySelectorAll('.tab-buttons button').forEach(b => b.classList.remove('active'));
    document.querySelector(`.tab-buttons button[onclick*="${tab}"]`).classList.add('active');
    refreshUserData();
}

async function refreshUserData() {
    await loadData();
    if (!appData || !appData.users[currentUser]) { alert('Session expired.'); userLogout(); return; }
    currentUserData = appData.users[currentUser];
    document.getElementById('userBalance').textContent = '₦' + currentUserData.balance.toFixed(2);
    document.getElementById('userInvested').textContent = '₦' + currentUserData.invested.toFixed(2);
    document.getElementById('userProfit').textContent = '₦' + currentUserData.profit.toFixed(2);
    document.getElementById('userReferralBonus').textContent = '₦' + (currentUserData.referralBonus||0).toFixed(2);
    document.getElementById('userPlan').textContent = currentUserData.plan;

    document.getElementById('refCode').textContent = currentUser;
    document.getElementById('refLink').textContent = currentUser;

    const badge = document.getElementById('userStatusBadge');
    badge.textContent = currentUserData.status.charAt(0).toUpperCase() + currentUserData.status.slice(1);
    badge.className = 'status-badge ' + currentUserData.status;

    const wBtn = document.getElementById('withdrawBtn');
    if (currentUserData.status === 'frozen') {
        wBtn.classList.add('disabled');
        wBtn.onclick = function() { alert('❌ Withdrawals disabled for frozen accounts.'); };
    } else {
        wBtn.classList.remove('disabled');
        wBtn.onclick = function() { showWithdrawModal(); };
    }

    const allTxs = [];
    (currentUserData.transactions||[]).forEach(tx => allTxs.push({...tx}));
    (currentUserData.withdrawals||[]).forEach(w => allTxs.push({
        date: w.date, type: 'withdraw', amount: -w.amount, status: w.status,
        description: `→ ${w.bank} (${w.accountName})`,
        bank: w.bank, accountName: w.accountName, accountNumber: w.accountNumber
    }));
    (currentUserData.referrals||[]).forEach(r => allTxs.push({
        date: r.date, type: 'referral', amount: r.bonus, status: 'approved',
        description: `Referral bonus from ${r.referee}`
    }));

    let filtered = allTxs;
    if (currentTxTab === 'deposits') filtered = allTxs.filter(tx => tx.type === 'deposit');
    else if (currentTxTab === 'withdrawals') filtered = allTxs.filter(tx => tx.type === 'withdraw');
    else if (currentTxTab === 'profits') filtered = allTxs.filter(tx => tx.type === 'profit');
    else if (currentTxTab === 'referrals') filtered = allTxs.filter(tx => tx.type === 'referral');

    const tbody = document.getElementById('userTransactions');
    if (!filtered.length) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:#64748b;">No transactions found.</td></tr>';
    } else {
        filtered.sort((a,b) => new Date(b.date)-new Date(a.date));
        tbody.innerHTML = filtered.map(tx => {
            const bc = tx.type==='deposit'?'deposit':tx.type==='profit'?'profit':tx.type==='referral'?'referral':
                      tx.status==='pending'?'pending':tx.status==='approved'?'approved':
                      tx.status==='declined'?'declined':'withdraw';
            const ac = (tx.type==='deposit'||tx.type==='profit'||tx.type==='referral')?'amount-green':
                      tx.status==='pending'?'amount-yellow':'amount-red';
            const sign = tx.type==='withdraw' && tx.amount<0 ? '' : (tx.type==='referral'?'+':(tx.type==='deposit'||tx.type==='profit')?'+':'');
            const amt = Math.abs(tx.amount);
            const sl = tx.status==='pending'?'Pending':tx.status==='approved'?'Approved':
                      tx.status==='declined'?'Declined':'Completed';
            let det = tx.description||'';
            if (tx.type==='withdraw' && tx.bank) det = `${tx.bank} - ${tx.accountName} (${tx.accountNumber})`;
            return `<tr><td>${escHtml(tx.date)}</td><td><span class="badge ${bc}">${escHtml(tx.type)}</span></td><td class="${ac}">${sign}₦${amt.toFixed(2)}</td><td><span class="badge ${bc}">${sl}</span></td><td style="font-size:12px;color:#94a3b8;">${escHtml(det)}</td></tr>`;
        }).join('');
    }
}

function copyRefLink() {
    const el = document.getElementById('refLink');
    const text = el.textContent;
    if (navigator.clipboard) {
        navigator.clipboard.writeText(text).then(() => {
            el.textContent = '✅ Copied!';
            setTimeout(() => refreshUserData(), 2000);
        });
    } else {
        const ta = document.createElement('textarea');
        ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
        el.textContent = '✅ Copied!';
        setTimeout(() => refreshUserData(), 2000);
    }
}

