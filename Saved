<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PrimeInvest - Investment Platform</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Segoe UI', -apple-system, Helvetica, Arial, sans-serif;
            background: #0a0e1a;
            color: #e0e0e0;
            min-height: 100vh;
        }

        .auth-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0a0e1a 0%, #1a1f35 50%, #0d1b2a 100%);
            padding: 20px;
        }
        .auth-box {
            background: #111827;
            border: 1px solid #1e293b;
            border-radius: 16px;
            padding: 40px 32px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }
        .auth-box .logo { text-align: center; margin-bottom: 30px; }
        .auth-box .logo h1 { font-size: 28px; color: #22c55e; font-weight: 700; }
        .auth-box .logo span { color: #e0e0e0; }
        .auth-box .logo p { font-size: 13px; color: #64748b; margin-top: 4px; }
        .auth-box h2 { font-size: 20px; margin-bottom: 22px; color: #f1f5f9; }
        .auth-box input, .auth-box select {
            width: 100%;
            padding: 13px 16px;
            margin-bottom: 13px;
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 8px;
            color: #fff;
            font-size: 14px;
            outline: none;
            transition: border 0.2s;
        }
        .auth-box input:focus, .auth-box select:focus { border-color: #22c55e; }
        .auth-box select option { background: #1e293b; }
        .auth-box .btn-primary {
            width: 100%;
            padding: 13px;
            background: #22c55e;
            color: #0a0e1a;
            font-weight: 700;
            font-size: 15px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 4px;
        }
        .auth-box .btn-primary:hover { background: #16a34a; }
        .auth-box .link { text-align: center; margin-top: 18px; font-size: 13px; color: #64748b; }
        .auth-box .link a { color: #22c55e; cursor: pointer; text-decoration: none; }
        .auth-box .link a:hover { text-decoration: underline; }
        .auth-box .error { color: #ef4444; font-size: 13px; margin-bottom: 12px; text-align: center; }
        .auth-box .success { color: #22c55e; font-size: 13px; margin-bottom: 12px; text-align: center; }
        .auth-tabs {
            display: flex;
            gap: 0;
            margin-bottom: 24px;
            border-bottom: 2px solid #1e293b;
        }
        .auth-tabs div {
            flex: 1;
            text-align: center;
            padding: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            color: #64748b;
            border-bottom: 2px solid transparent;
            margin-bottom: -2px;
            transition: all 0.2s;
        }
        .auth-tabs div.active { color: #22c55e; border-bottom-color: #22c55e; }

        .admin-hidden-link { text-align: center; margin-top: 24px; padding-top: 18px; border-top: 1px solid #1a1f35; }
        .admin-hidden-link a { color: #1e293b; font-size: 11px; text-decoration: none; cursor: pointer; transition: color 0.3s; user-select: none; }
        .admin-hidden-link a:hover { color: #334155; }

        .admin-login-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.85);
            z-index: 999;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .admin-login-overlay.active { display: flex; }
        .admin-login-box {
            background: #111827;
            border: 1px solid #1e293b;
            border-radius: 14px;
            padding: 32px;
            width: 100%;
            max-width: 380px;
        }
        .admin-login-box h3 { font-size: 18px; color: #f1f5f9; margin-bottom: 6px; }
        .admin-login-box p.sub { font-size: 12px; color: #64748b; margin-bottom: 18px; }
        .admin-login-box input {
            width: 100%;
            padding: 11px 14px;
            margin-bottom: 12px;
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 6px;
            color: #fff;
            font-size: 14px;
            outline: none;
        }
        .admin-login-box input:focus { border-color: #3b82f6; }
        .admin-login-box .btn-admin { width: 100%; padding: 11px; background: #3b82f6; color: #fff; font-weight: 600; font-size: 14px; border: none; border-radius: 6px; cursor: pointer; transition: background 0.2s; }
        .admin-login-box .btn-admin:hover { background: #2563eb; }
        .admin-login-box .admin-error { color: #ef4444; font-size: 13px; margin-bottom: 10px; text-align: center; }
        .admin-login-box .close-admin { float: right; background: none; border: none; color: #64748b; font-size: 20px; cursor: pointer; padding: 0 4px; }
        .admin-login-box .close-admin:hover { color: #e0e0e0; }

        .dashboard { display: none; }
        .dashboard.active { display: block; }

        .topbar {
            background: #111827;
            border-bottom: 1px solid #1e293b;
            padding: 14px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .topbar .brand { font-size: 20px; font-weight: 700; color: #22c55e; }
        .topbar .brand span { color: #e0e0e0; }
        .topbar .user-menu { display: flex; align-items: center; gap: 16px; }
        .topbar .user-menu .username { font-size: 14px; color: #94a3b8; }
        .topbar .user-menu button { padding: 8px 18px; background: #1e293b; color: #e0e0e0; border: 1px solid #334155; border-radius: 6px; cursor: pointer; font-size: 13px; transition: all 0.2s; }
        .topbar .user-menu button:hover { background: #334155; }
        .topbar .user-menu .logout-btn { background: transparent; border-color: #ef4444; color: #ef4444; }
        .topbar .user-menu .logout-btn:hover { background: #ef4444; color: #fff; }

        .dashboard-content { max-width: 1100px; margin: 0 auto; padding: 24px; }

        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }
        .stat-card { background: #111827; border: 1px solid #1e293b; border-radius: 12px; padding: 20px; }
        .stat-card .label { font-size: 12px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
        .stat-card .value { font-size: 26px; font-weight: 700; color: #f1f5f9; }
        .stat-card .green { color: #22c55e; }
        .stat-card .status-badge { display: inline-block; padding: 4px 12px; border-radius: 12px; font-size: 13px; font-weight: 600; }
        .status-badge.active { background: #065f4633; color: #22c55e; }
        .status-badge.frozen { background: #5f4a1e33; color: #facc15; }
        .status-badge.closed { background: #5f1e1e33; color: #ef4444; }

        .quick-actions { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 12px; margin-bottom: 24px; }
        .quick-action { background: #111827; border: 1px solid #1e293b; border-radius: 10px; padding: 16px 20px; text-align: center; cursor: pointer; transition: all 0.2s; }
        .quick-action:hover { border-color: #22c55e; transform: translateY(-2px); }
        .quick-action .icon { font-size: 28px; margin-bottom: 6px; }
        .quick-action h3 { font-size: 14px; color: #e0e0e0; margin-bottom: 2px; }
        .quick-action p { font-size: 12px; color: #64748b; }
        .quick-action.disabled { opacity: 0.5; cursor: not-allowed; }
        .quick-action.disabled:hover { border-color: #1e293b; transform: none; }

        .section-title { font-size: 18px; font-weight: 600; color: #f1f5f9; margin-bottom: 14px; margin-top: 24px; }
        .section-title:first-child { margin-top: 0; }
        .table-wrap { background: #111827; border: 1px solid #1e293b; border-radius: 12px; overflow: hidden; margin-bottom: 24px; }
        table { width: 100%; border-collapse: collapse; font-size: 14px; }
        table th { background: #1a1f35; text-align: left; padding: 12px 16px; color: #94a3b8; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #1e293b; }
        table td { padding: 12px 16px; border-bottom: 1px solid #1a1f35; }
        table tr:last-child td { border-bottom: none; }
        table tr:hover td { background: #0f172a; }
        .badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
        .badge.deposit { background: #065f4633; color: #22c55e; }
        .badge.profit { background: #1e3a5f33; color: #60a5fa; }
        .badge.withdraw { background: #5f1e1e33; color: #ef4444; }
        .badge.pending { background: #5f4a1e33; color: #facc15; }
        .badge.approved { background: #065f4633; color: #22c55e; }
        .badge.declined { background: #5f1e1e33; color: #ef4444; }
        .badge.referral { background: #4a1a5f33; color: #c084fc; }
        .badge.active { background: #065f4633; color: #22c55e; }
        .badge.frozen { background: #5f4a1e33; color: #facc15; }
        .badge.closed { background: #5f1e1e33; color: #ef4444; }
        .amount-green { color: #22c55e; font-weight: 600; }
        .amount-red { color: #ef4444; font-weight: 600; }
        .amount-yellow { color: #facc15; font-weight: 600; }
        .amount-purple { color: #c084fc; font-weight: 600; }

        .admin-section { background: #111827; border: 1px solid #1e293b; border-radius: 12px; padding: 24px; margin-bottom: 24px; }
        .admin-section h3 { font-size: 16px; color: #f1f5f9; margin-bottom: 16px; }
        .admin-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 16px; }
        .admin-card { background: #0f172a; border: 1px solid #1e293b; border-radius: 10px; padding: 16px; }
        .admin-card .user-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .admin-card .user-header h4 { font-size: 15px; color: #f1f5f9; }
        .admin-card .user-detail { font-size: 13px; color: #94a3b8; margin-bottom: 3px; }
        .admin-card .user-detail strong { color: #e0e0e0; }
        .admin-card .admin-actions { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
        .admin-card .admin-actions input, .admin-card .admin-actions select { padding: 6px 10px; background: #1e293b; border: 1px solid #334155; border-radius: 4px; color: #fff; font-size: 12px; width: 100px; }
        .admin-card .admin-actions select { width: auto; }
        .admin-card .admin-actions select option { background: #1e293b; }
        .admin-card .admin-actions button { padding: 6px 12px; border: none; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 600; }
        .btn-green { background: #22c55e; color: #0a0e1a; }
        .btn-green:hover { background: #16a34a; }
        .btn-blue { background: #3b82f6; color: #fff; }
        .btn-blue:hover { background: #2563eb; }
        .btn-red { background: #ef4444; color: #fff; }
        .btn-red:hover { background: #dc2626; }
        .btn-yellow { background: #facc15; color: #0a0e1a; }
        .btn-yellow:hover { background: #eab308; }

        .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; align-items: center; justify-content: center; padding: 20px; }
        .modal-overlay.active { display: flex; }
        .modal { background: #111827; border: 1px solid #1e293b; border-radius: 14px; padding: 28px; width: 100%; max-width: 480px; max-height: 90vh; overflow-y: auto; }
        .modal h3 { font-size: 18px; color: #f1f5f9; margin-bottom: 16px; }
        .modal input, .modal select { width: 100%; padding: 11px 14px; margin-bottom: 12px; background: #1e293b; border: 1px solid #334155; border-radius: 6px; color: #fff; font-size: 14px; outline: none; }
        .modal input:focus, .modal select:focus { border-color: #22c55e; }
        .modal select option { background: #1e293b; }
        .modal .modal-actions { display: flex; gap: 10px; margin-top: 6px; }
        .modal .modal-actions button { flex: 1; padding: 11px; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 14px; }
        .modal .modal-actions .cancel { background: #1e293b; color: #94a3b8; }
        .modal .modal-actions .cancel:hover { background: #334155; }

        .hidden { display: none !important; }
        .tab-buttons { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
        .tab-buttons button { padding: 8px 20px; background: #1e293b; border: 1px solid #334155; border-radius: 6px; color: #94a3b8; cursor: pointer; font-size: 13px; font-weight: 600; transition: all 0.2s; }
        .tab-buttons button.active { background: #22c55e33; border-color: #22c55e; color: #22c55e; }
        .tab-buttons button:hover { border-color: #22c55e; }

        .referral-box {
            background: linear-gradient(135deg, #1a1f35, #111827);
            border: 1px solid #3b82f633;
            border-radius: 12px;
            padding: 18px;
            margin-bottom: 18px;
        }
        .referral-box .r-label { font-size: 12px; color: #64748b; text-transform: uppercase; letter-spacing: 1px; }
        .referral-box .r-code { font-size: 22px; font-weight: 700; color: #60a5fa; margin: 6px 0; }
        .referral-box .r-link { font-size: 13px; color: #3b82f6; word-break: break-all; cursor: pointer; }
        .referral-box .r-link:hover { text-decoration: underline; }

        .reset-section { display: none; margin-top: 12px; padding: 12px; background: #0f172a; border-radius: 8px; border: 1px solid #1e293b; }
        .reset-section.show { display: block; }

        @media (max-width: 640px) {
            .auth-box { padding: 24px 18px; }
            .topbar { padding: 12px 16px; flex-wrap: wrap; gap: 8px; }
            .stats-grid { grid-template-columns: 1fr 1fr; }
            .admin-grid { grid-template-columns: 1fr; }
            .dashboard-content { padding: 16px; }
        }
    </style>
</head>
<body>

<!-- AUTH CONTAINER -->
<div id="authContainer" class="auth-container">
    <div class="auth-box">
        <div class="logo">
            <h1>Prime<span>Invest</span></h1>
            <p>Secure Investment Platform — NGN</p>
        </div>
        <div class="auth-tabs">
            <div class="active" onclick="showAuthTab('login')">Login</div>
            <div onclick="showAuthTab('register')">Register</div>
        </div>

        <!-- LOGIN FORM -->
        <div id="loginForm">
            <h2>Welcome Back</h2>
            <div id="loginError" class="error"></div>
            <input type="text" id="loginUsername" placeholder="Username" autocomplete="off">
            <input type="password" id="loginPassword" placeholder="Password">
            <button class="btn-primary" onclick="userLogin()">Sign In</button>
            <div class="link">
                <a href="#" onclick="event.preventDefault();showAuthTab('register');">Don't have an account? Register</a>
            </div>
            <div class="link" style="margin-top:6px;">
                <a href="#" onclick="event.preventDefault();toggleResetPassword();">Forgot password?</a>
            </div>
            <div id="resetSection" class="reset-section">
                <p style="font-size:13px;color:#64748b;margin-bottom:10px;">Password reset is coming soon. For now, contact admin to reset your password.</p>
                <input type="text" id="resetUsername" placeholder="Enter your username">
                <button class="btn-primary" onclick="resetPasswordRequest()">Request Reset</button>
                <div id="resetMsg" style="font-size:13px;margin-top:8px;text-align:center;"></div>
            </div>
        </div>

        <!-- REGISTER FORM -->
        <div id="registerForm" class="hidden">
            <h2>Create Account</h2>
            <div id="registerError" class="error"></div>
            <div id="registerSuccess" class="success"></div>
            <input type="text" id="regUsername" placeholder="Choose a username" autocomplete="off">
            <input type="text" id="regFullname" placeholder="Full name">
            <input type="email" id="regEmail" placeholder="Email address">
            <input type="text" id="regPhone" placeholder="Phone number (optional)">
            <input type="password" id="regPassword" placeholder="Password">
            <input type="text" id="regReferral" placeholder="Referral code (optional)" autocomplete="off">
            <button class="btn-primary" onclick="userRegister()">Create Account</button>
            <div class="link">
                <a href="#" onclick="event.preventDefault();showAuthTab('login');">Already have an account? Login</a>
            </div>
        </div>

        <div class="admin-hidden-link">
            <a onclick="openAdminLogin()">●</a>
        </div>
    </div>
</div>

<!-- ADMIN LOGIN OVERLAY -->
<div id="adminLoginOverlay" class="admin-login-overlay">
    <div class="admin-login-box">
        <button class="close-admin" onclick="closeAdminLogin()">✕</button>
        <h3>🔐 Admin Access</h3>
        <p class="sub">Restricted area — authorized personnel only</p>
        <div id="adminLoginError" class="admin-error"></div>
        <input type="text" id="adminLoginUser" placeholder="Admin username" autocomplete="off">
        <input type="password" id="adminLoginPass" placeholder="Admin password">
        <button class="btn-admin" onclick="adminLogin()">Access Dashboard</button>
    </div>
</div>

<!-- USER DASHBOARD -->
<div id="userDashboard" class="dashboard">
    <div class="topbar">
        <div class="brand">Prime<span>Invest</span></div>
        <div class="user-menu">
            <span class="username" id="displayUsername">user</span>
            <span id="userStatusBadge" class="status-badge active" style="font-size:11px;padding:3px 10px;border-radius:10px;">Active</span>
            <button onclick="userLogout()" class="logout-btn">Logout</button>
        </div>
    </div>
    <div class="dashboard-content">
        <div class="stats-grid">
            <div class="stat-card"><div class="label">Balance (NGN)</div><div class="value green" id="userBalance">₦0.00</div></div>
            <div class="stat-card"><div class="label">Total Invested (NGN)</div><div class="value" id="userInvested">₦0.00</div></div>
            <div class="stat-card"><div class="label">Total Profit (NGN)</div><div class="value green" id="userProfit">₦0.00</div></div>
            <div class="stat-card"><div class="label">Referral Bonus (NGN)</div><div class="value" style="color:#c084fc;font-size:22px;" id="userReferralBonus">₦0.00</div></div>
            <div class="stat-card"><div class="label">Plan</div><div class="value" id="userPlan" style="font-size:20px;">-</div></div>
        </div>

        <!-- Referral Box -->
        <div class="referral-box">
            <div class="r-label">Your Referral Code</div>
            <div class="r-code" id="refCode">-</div>
            <div class="r-link" id="refLink" onclick="copyRefLink()">Click to copy referral code</div>
        </div>

        <div class="quick-actions">
            <div class="quick-action" onclick="showDepositModal()"><div class="icon">💰</div><h3>Deposit</h3><p>Fund via card / bank — Min ₦2,500</p></div>
            <div class="quick-action" id="withdrawBtn" onclick="showWithdrawModal()"><div class="icon">💸</div><h3>Withdraw</h3><p>Request withdrawal — Min ₦1,000</p></div>
            <div class="quick-action" onclick="showProfileModal()"><div class="icon">👤</div><h3>Profile</h3><p>View account details</p></div>
            <div class="quick-action" onclick="refreshUserData()"><div class="icon">🔄</div><h3>Refresh</h3><p>Update account data</p></div>
        </div>

        <div class="section-title" id="interestStatus" style="font-size:13px;color:#60a5fa;margin-bottom:8px;"></div>

        <div class="section-title">Transaction History</div>
        <div class="tab-buttons">
            <button class="active" onclick="showTxTab('all')">All</button>
            <button onclick="showTxTab('deposits')">Deposits</button>
            <button onclick="showTxTab('withdrawals')">Withdrawals</button>
            <button onclick="showTxTab('profits')">Profits</button>
            <button onclick="showTxTab('referrals')">Referrals</button>
        </div>
        <div class="table-wrap">
            <table>
                <thead><tr><th>Date</th><th>Type</th><th>Amount</th><th>Status</th><th>Details</th></tr></thead>
                <tbody id="userTransactions"></tbody>
            </table>
        </div>

        <!-- ADMIN SECTION -->
        <div id="adminSection" class="hidden">
            <div class="section-title" style="color:#22c55e;">⚙ Admin Dashboard — Full Control</div>

            <div class="admin-section">
                <h3>⚙️ Platform Settings</h3>
                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-bottom:12px;">
                    <div>
                        <label style="font-size:12px;color:#64748b;">Daily Interest Rate (%)</label>
                        <input type="number" id="adminInterestRate" step="0.1" min="0" style="padding:8px 12px;background:#1e293b;border:1px solid #334155;border-radius:6px;color:#fff;width:100px;font-size:14px;">
                    </div>
                    <button onclick="adminUpdateInterest()" class="btn-blue" style="padding:10px 20px;margin-top:12px;">Set Interest Rate</button>
                    <div style="font-size:12px;color:#94a3b8;margin-top:12px;">
                        💡 Current: <span id="currentInterestDisplay">2%</span> daily — applied automatically when users log in
                    </div>
                </div>
                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-bottom:4px;">
                    <label style="font-size:12px;color:#64748b;">Withdrawal Day Restriction</label>
                    <select id="adminWithdrawDay" style="padding:8px 12px;background:#1e293b;border:1px solid #334155;border-radius:6px;color:#fff;font-size:14px;">
                        <option value="5">Friday (Default)</option>
                        <option value="0">Sunday</option>
                        <option value="1">Monday</option>
                        <option value="2">Tuesday</option>
                        <option value="3">Wednesday</option>
                        <option value="4">Thursday</option>
                        <option value="6">Saturday</option>
                        <option value="-1">No restriction (Any day)</option>
                    </select>
                    <button onclick="adminUpdateWithdrawDay()" class="btn-yellow" style="padding:10px 20px;margin-top:8px;">Set Withdrawal Day</button>
                    <div style="font-size:12px;color:#94a3b8;margin-top:8px;">
                        💡 Current: <span id="currentWithdrawDayDisplay">Friday</span>
                    </div>
                </div>
            </div>

            <div class="admin-section">
                <h3>Withdrawal Requests (Pending)</h3>
                <div id="pendingWithdrawals"></div>
            </div>

            <!-- ✅ UPDATED: Paystack Settings with Test/Live Mode -->
            <div class="admin-section">
                <h3>💳 Paystack Settings</h3>
                <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:8px;">
                    <div style="flex:1;min-width:200px;">
                        <label style="font-size:12px;color:#64748b;">🔴 LIVE Public Key</label>
