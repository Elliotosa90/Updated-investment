async function changeAdminPassword() {
    const cp = document.getElementById('adminCurrentPass').value.trim();
    const np = document.getElementById('adminNewPassInput').value.trim();
    const msg = document.getElementById('changePassMsg');
    if (!cp||!np) { msg.textContent = '❌ Fill both fields.'; msg.style.color = '#ef4444'; return; }
    if (np.length<4) { msg.textContent = '❌ Min 4 characters.'; msg.style.color = '#ef4444'; return; }
    await loadData();
    if (!appData) { msg.textContent = '❌ Failed.'; msg.style.color='#ef4444'; return; }
    if (appData.admin.password !== cp) { msg.textContent = '❌ Current password wrong.'; msg.style.color='#ef4444'; return; }
    appData.admin.password = np;
    const ok = await saveData();
    if (ok) { msg.textContent = '✅ Password changed.'; msg.style.color = '#22c55e'; }
    else { msg.textContent = '❌ Failed.'; msg.style.color='#ef4444'; }
    document.getElementById('adminCurrentPass').value = '';
    document.getElementById('adminNewPassInput').value = '';
    setTimeout(()=>msg.textContent='', 3000);
}

async function adminPayAllProfits() {
    if (!confirm(`Apply ${(appData.settings&&appData.settings.interestRate)||2}% daily interest to all active users?`)) return;
    await loadData();
    const rate = (appData.settings && appData.settings.interestRate) || 2;
    const now = new Date();
    const ds = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')} ${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
    const today = now.toDateString();
    let c = 0;
    for (const [u, user] of Object.entries(appData.users)) {
        if (user.status !== 'active' || user.balance <= 0) continue;
        if (user.lastInterestDate === today) continue;
        const p = user.balance * (rate / 100);
        user.balance += p;
        user.profit += p;
        if (!user.transactions) user.transactions = [];
        user.transactions.push({ date: ds, type: 'profit', amount: p, description: `Daily interest ${rate}%` });
        user.lastInterestDate = today;
        c++;
    }
    await saveData();
    document.getElementById('adminActionMsg').textContent = `✅ ${rate}% interest applied to ${c} users.`;
    refreshAdminData();
}

async function adminResetAll() {
    if (!confirm('⚠️ Delete ALL user data except admin?')) return;
    if (!confirm('This cannot be undone. Continue?')) return;
    await loadData();
    appData.users = {};
    await saveData();
    refreshAdminData();
    document.getElementById('adminActionMsg').textContent = '✅ All user data reset.';
}

