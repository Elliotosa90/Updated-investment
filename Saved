function getWithdrawDayRestriction() {
    if (!appData.settings || appData.settings.withdrawDay === undefined) return 5;
    return parseInt(appData.settings.withdrawDay);
}

function getWithdrawDayName(day) {
    const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    if (day === -1) return 'Any day (no restriction)';
    return days[day];
}

function showWithdrawModal() {
    if (currentUserData.status === 'frozen') { alert('❌ Withdrawals disabled.'); return; }
    const allowedDay = getWithdrawDayRestriction();
    if (allowedDay !== -1) {
        const today = new Date();
        if (today.getDay() !== allowedDay) {
            const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
            alert(`❌ Withdrawals are currently restricted to ${days[allowedDay]}s. Today is ${days[today.getDay()]}. Please come back on ${days[allowedDay]}.`);
            return;
